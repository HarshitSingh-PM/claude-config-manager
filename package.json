{
  "name": "claude-config-ui",
  "version": "0.9.0",
  "description": "Local, open-source UI for editing every Claude Code config file — settings, CLAUDE.md, MCP servers, subagents, slash commands, credentials, hooks. User / project-shared / project-local / enterprise scopes, with community presets and tooltips.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "config",
    "settings",
    "mcp",
    "agents",
    "developer-tools",
    "cli",
    "tui",
    "manager"
  ],
  "license": "MIT",
  "author": "Harshit Singh <singhharshit.pm@gmail.com>",
  "homepage": "https://github.com/HarshitSingh-PM/claude-config-manager#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarshitSingh-PM/claude-config-manager.git"
  },
  "bugs": {
    "url": "https://github.com/HarshitSingh-PM/claude-config-manager/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "bin": {
    "claude-config-ui": "bin/start.js",
    "ccm": "bin/start.js"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "next build && node scripts/pack-standalone.js",
    "start": "next start",
    "lint": "eslint",
    "prepublishOnly": "npm run build:standalone",
    "ccm": "node bin/start.js",
    "electron": "npm run build:standalone && electron .",
    "dmg": "npm run build:standalone && electron-builder --mac dmg",
    "exe": "npm run build:standalone && electron-builder --win nsis"
  },
  "build": {
    "appId": "dev.harshitsingh.claude-config-ui",
    "productName": "Claude Config",
    "copyright": "© 2026 Harshit Singh — MIT",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "!**/*.{md,bak}"
    ],
    "afterPack": "build/afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null,
      "type": "distribution",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "iconSize": 110,
      "contents": [
        {
          "x": 140,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 560,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Config",
      "deleteAppDataOnUninstall": false
    },
    "asar": true
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
